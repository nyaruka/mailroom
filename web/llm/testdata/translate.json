        "path": "/mi/llm/translate",
        "body": {
            "org_id": 1,
            "llm_id": 10002,
            "source": "eng",
            "target": "spa",
            "items": {
                "a1f0e2c4": {
                    "text": ["Hi @contact.name"],
                    "quick_replies": ["Yes", "No"]
                },
                "b7d91a22": {"arguments": ["yes yeah"]}
            }
        },
        "status": 200,
        "response": {
            "items": {
                "a1f0e2c4": {
                    "text": ["T-Hi @contact.name"],
                    "quick_replies": ["T-Yes", "T-No"]
                },
                "b7d91a22": {"arguments": ["T-yes yeah"]}
            }
        }
    },
