    {
        "label": "eng to spa multi-item batch",
        "method": "POST",
        "path": "/mi/llm/translate",
        "body": {
            "org_id": 1,
            "llm_id": 10002,
            "source": "eng",
            "target": "spa",
            "items": {
                "a1f0e2c4-5b3e-4d7a-9c2f-1e8d6a4b7c35:text": ["\\return [\"Hola @contact.name\"]"],
                "a1f0e2c4-5b3e-4d7a-9c2f-1e8d6a4b7c35:quick_replies": ["\\return [\"Sí\",\"No\"]", "_"],
                "b7d91a22-8e4f-4a1b-9d3c-2f7e5b8a9c10:arguments": ["\\return [\"sí claro\"]"]
            }
        },
        "status": 200,
        "response": {
            "items": {
                "a1f0e2c4-5b3e-4d7a-9c2f-1e8d6a4b7c35:text": ["Hola @contact.name"],
                "a1f0e2c4-5b3e-4d7a-9c2f-1e8d6a4b7c35:quick_replies": ["Sí", "No"],
                "b7d91a22-8e4f-4a1b-9d3c-2f7e5b8a9c10:arguments": ["sí claro"]
            }
        }
    },
