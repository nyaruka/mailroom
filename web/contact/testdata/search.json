[
    {
        "label": "error if fields not provided",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {},
        "status": 400,
        "response": {
            "error": "request failed validation: field 'org_id' is required, field 'group_id' is required"
        }
    },
    {
        "label": "query error if property not resolveable",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "birthday = tomorrow",
            "group_id": 10000
        },
        "status": 422,
        "response": {
            "error": "can't resolve 'birthday' to attribute, scheme or field",
            "code": "query:unknown_property",
            "extra": {
                "property": "birthday"
            }
        }
    },
    {
        "label": "query error if property not convertable",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "age > tomorrow",
            "group_id": 10000
        },
        "status": 422,
        "response": {
            "error": "can't convert 'tomorrow' to a number",
            "code": "query:invalid_number",
            "extra": {
                "value": "tomorrow"
            }
        }
    },
    {
        "label": "valid unstructured query",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "Ann",
            "group_id": 10000
        },
        "status": 200,
        "response": {
            "query": "name ~ \"Ann\"",
            "contact_uuids": [
                "a393abc0-283d-4c9b-a1b3-641a035c34bf"
            ],
            "total": 1,
            "metadata": {
                "attributes": [
                    "name"
                ],
                "schemes": [],
                "fields": [],
                "groups": [],
                "allow_as_group": true
            }
        }
    },
    {
        "label": "can exclude specific contacts",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "Ann OR Cat",
            "group_id": 10000,
            "exclude_uuids": [
                "b699a406-7e44-49be-9f01-1a82893e8a10",
                "cd024bcd-f473-4719-a00a-bd0bb1190135"
            ]
        },
        "status": 200,
        "response": {
            "query": "name ~ \"Ann\" OR name ~ \"Cat\"",
            "contact_uuids": [
                "a393abc0-283d-4c9b-a1b3-641a035c34bf"
            ],
            "total": 1,
            "metadata": {
                "attributes": [
                    "name"
                ],
                "schemes": [],
                "fields": [],
                "groups": [],
                "allow_as_group": true
            }
        }
    },
    {
        "label": "valid search on two fields",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "AGE = 10 and gender = M",
            "group_id": 10000
        },
        "status": 200,
        "response": {
            "query": "fields.age = 10 AND fields.gender = \"M\"",
            "contact_uuids": [],
            "total": 0,
            "metadata": {
                "attributes": [],
                "schemes": [],
                "fields": [
                    {
                        "key": "age",
                        "name": "Age"
                    },
                    {
                        "key": "gender",
                        "name": "Gender"
                    }
                ],
                "groups": [],
                "allow_as_group": true
            }
        }
    },
