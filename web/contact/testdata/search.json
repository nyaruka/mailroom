[
    {
        "label": "error if fields not provided",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {},
        "status": 400,
        "response": {
            "error": "request failed validation: field 'org_id' is required, field 'group_id' is required"
        }
    },
    {
        "label": "query error if property not resolveable",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "birthday = tomorrow",
            "group_id": 10000
        },
        "status": 422,
        "response": {
            "error": "can't resolve 'birthday' to attribute, scheme or field",
            "code": "query:unknown_property",
            "extra": {
                "property": "birthday"
            }
        }
    },
    {
        "label": "query error if property not convertable",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "age > tomorrow",
            "group_id": 10000
        },
        "status": 422,
        "response": {
            "error": "can't convert 'tomorrow' to a number",
            "code": "query:invalid_number",
            "extra": {
                "value": "tomorrow"
            }
        }
    },
    {
        "label": "valid unstructured query",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "Ann",
            "group_id": 10000
        },
        "status": 200,
        "response": {
            "query": "name ~ \"Ann\"",
            "contact_ids": [],
            "total": 0,
            "metadata": {
                "attributes": [
                    "name"
                ],
                "schemes": [],
                "fields": [],
                "groups": [],
                "allow_as_group": true
            }
        }
    },
    {
        "label": "can exclude specific contacts",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "Ann OR Cat",
            "group_id": 10000,
            "exclude_ids": [
                10001,
                10002
            ]
        },
        "status": 200,
        "response": {
            "query": "name ~ \"Ann\" OR name ~ \"Cat\"",
            "contact_ids": [],
            "total": 0,
            "metadata": {
                "attributes": [
                    "name"
                ],
                "schemes": [],
                "fields": [],
                "groups": [],
                "allow_as_group": true
            }
        }
    },
    {
        "label": "valid search on two fields",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "AGE = 10 and gender = M",
            "group_id": 10000
        },
        "status": 200,
        "response": {
            "query": "fields.age = 10 AND fields.gender = \"M\"",
            "contact_ids": [],
            "total": 0,
            "metadata": {
                "attributes": [],
                "schemes": [],
                "fields": [
                    {
                        "key": "age",
                        "name": "Age"
                    },
                    {
                        "key": "gender",
                        "name": "Gender"
                    }
                ],
                "groups": [],
                "allow_as_group": true
            }
        }
    },
    {
        "label": "empty query on different group",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "",
            "group_id": 10006
        },
        "status": 200,
        "response": {
            "query": "",
            "contact_ids": [],
            "total": 0
        }
    },
    {
        "label": "empty query on different group with limit",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "",
            "group_id": 10006,
            "limit": 5
        },
        "status": 200,
        "response": {
            "query": "",
            "contact_ids": [],
            "total": 0
        }
    },
    {
        "label": "empty query on different group with limit and sort",
        "method": "POST",
        "path": "/mi/contact/search",
        "body": {
            "org_id": 1,
            "query": "",
            "group_id": 10006,
            "limit": 5,
            "sort": "id"
        },
        "status": 200,
        "response": {
            "query": "",
            "contact_ids": [],
            "total": 0
        }
    }
]